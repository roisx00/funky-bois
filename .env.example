# ── X (Twitter) OAuth 2.0 ───────────────────────────────────────────────────
# Get these from developer.twitter.com → Your App → Keys and Tokens

# Exposed to the browser (Vite prefix required)
VITE_X_CLIENT_ID=your_client_id_here

# Server-only (Vercel env vars — never commit to git)
X_CLIENT_ID=your_client_id_here
X_CLIENT_SECRET=your_client_secret_here

# Redirect URI — must match exactly what you set in the X Developer portal
# For local dev:  http://localhost:5173/
# For prod:       https://funky-bois.vercel.app/
