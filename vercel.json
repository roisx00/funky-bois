{
  "framework": null,
  "buildCommand": "npm run build",
  "devCommand": "node scripts/build.js && node scripts/preview.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[...path]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
